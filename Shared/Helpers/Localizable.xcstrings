    "about_description" : {
      "comment" : "Descriptive paragraph about the app and its mission\n",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal ist eine App, die von Brink 13 Labs, LLC in Nashville, TN entwickelt wurde. Ziel von BitLocal ist es, die Hyperbitcoinisierung zu unterstützen, indem Menschen mit lokalen Unternehmen verbunden werden, die Bitcoin akzeptieren – mein Beitrag zur Bitcoin-Community. Die Standortdaten in BitLocal stammen von OpenStreetMap über die BTC Map API."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal is an app developed by Brink 13 Labs, LLC in Nashville, TN. BitLocal’s mission is to support hyperbitcoinization by connecting people with local businesses that accept bitcoin and is our contribution to the bitcoin community. Location data displayed in BitLocal is retrieved from OpenStreetMap through the BTC Map API."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal es una aplicación desarrollada por Brink 13 Labs, LLC en Nashville, TN. La misión de BitLocal es apoyar la hiperbitcoinización conectando a personas con negocios locales que aceptan bitcoin y es mi contribución a la comunidad bitcoin. Los datos de ubicación que se muestran en BitLocal se obtienen de OpenStreetMap a través de la API de BTC Map."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal es una aplicación desarrollada por Brink 13 Labs, LLC en Nashville, TN. La misión de BitLocal es apoyar la hiperbitcoinización conectando a las personas con negocios locales que aceptan bitcoin; es mi contribución a la comunidad bitcoiner. Los datos de ubicación en BitLocal se obtienen de OpenStreetMap mediante la API de BTC Map."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal est une application développée par Brink 13 Labs, LLC à Nashville, Tennessee. La mission de BitLocal est de soutenir l’hyperbitcoinisation en connectant les utilisateurs avec des commerces locaux qui acceptent le bitcoin. C’est ma contribution à la communauté Bitcoin. Les données de localisation affichées dans BitLocal proviennent d’OpenStreetMap via l’API BTC Map."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal est une application développée par Brink 13 Labs, LLC à Nashville, Tennessee. La mission de BitLocal est de soutenir l’hyperbitcoinisation en reliant les gens aux commerces locaux qui acceptent le bitcoin. C’est ma contribution à la communauté Bitcoin. Les données de localisation affichées dans BitLocal proviennent d’OpenStreetMap grâce à l’API BTC Map."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal è un'app sviluppata da Brink 13 Labs, LLC a Nashville, Tennessee. La missione di BitLocal è sostenere l’iperbitcoinizzazione collegando le persone alle attività locali che accettano bitcoin: è il mio contributo alla comunità Bitcoin. I dati sulla posizione visualizzati in BitLocal sono ottenuti da OpenStreetMap tramite l’API di BTC Map."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal is een app ontwikkeld door Brink 13 Labs, LLC in Nashville, TN. De missie van BitLocal is om hyperbitcoinisatie te ondersteunen door mensen te verbinden met lokale bedrijven die bitcoin accepteren. Het is mijn bijdrage aan de bitcoincommunity. Locatiegegevens in BitLocal worden opgehaald via OpenStreetMap met behulp van de BTC Map API."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal เป็นแอปที่พัฒนาโดย Brink 13 Labs, LLC ในแนชวิลล์ รัฐเทนเนสซี ภารกิจของ BitLocal คือสนับสนุนการใช้บิตคอยน์อย่างแพร่หลาย โดยเชื่อมต่อผู้คนกับธุรกิจท้องถิ่นที่รับบิตคอยน์ ซึ่งเป็นส่วนหนึ่งของการมีส่วนร่วมในชุมชนบิตคอยน์ ข้อมูลตำแหน่งที่แสดงใน BitLocal ดึงมาจาก OpenStreetMap ผ่าน API ของ BTC Map"
          }
        }
      }
    },
