    "add_business_info_footer" : {
      "comment" : "Footer text on add business info screen",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sobald Ihr Unternehmen zu BTC Map hinzugefügt wurde, erscheint es automatisch in BitLocal, wenn die App ihre Daten das nächste Mal aktualisiert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Once your business is added to BTC Map, it will automatically appear in BitLocal the next time the app refreshes its data."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una vez que tu negocio se añada a BTC Map, aparecerá automáticamente en BitLocal la próxima vez que la aplicación actualice sus datos."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una vez que tu negocio se agregue a BTC Map, aparecerá automáticamente en BitLocal la próxima vez que la aplicación actualice sus datos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une fois votre établissement ajouté à BTC Map, il apparaîtra automatiquement dans BitLocal lors de la prochaine actualisation des données."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une fois votre commerce ajouté à BTC Map, il apparaîtra automatiquement dans BitLocal lors de la prochaine actualisation des données."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una volta aggiunta la tua attività a BTC Map, apparirà automaticamente in BitLocal al prossimo aggiornamento dei dati dell'app."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zodra je bedrijf is toegevoegd aan BTC Map, verschijnt het automatisch in BitLocal wanneer de app de gegevens ververst."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "เมื่อธุรกิจของคุณถูกเพิ่มใน BTC Map แล้ว จะปรากฏใน BitLocal โดยอัตโนมัติเมื่อแอปรีเฟรชข้อมูลครั้งถัดไป"
