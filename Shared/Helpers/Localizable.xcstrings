    "add_business_info_timing_description" : {
      "comment" : "Description explaining timing expectations",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Bearbeitungszeiten variieren je nach Verfügbarkeit der Freiwilligen. Die meisten Einreichungen werden innerhalb weniger Tage überprüft, aber es kann in Stoßzeiten länger dauern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Processing times vary depending on volunteer availability. Most submissions are reviewed within a few days, but it may take longer during busy periods."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los tiempos de procesamiento varían según la disponibilidad de los voluntarios. La mayoría de los envíos se revisan en unos pocos días, pero puede tardar más durante períodos de alta demanda."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los tiempos de procesamiento varían según la disponibilidad de los voluntarios. La mayoría de los envíos se revisan en unos pocos días, pero puede tardar más durante períodos de alta demanda."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les délais de traitement varient selon la disponibilité des bénévoles. La plupart des soumissions sont examinées en quelques jours, mais cela peut prendre plus de temps pendant les périodes chargées."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les délais de traitement varient selon la disponibilité des bénévoles. La plupart des soumissions sont examinées en quelques jours, mais cela peut prendre plus de temps pendant les périodes achalandées."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I tempi di elaborazione variano a seconda della disponibilità dei volontari. La maggior parte delle richieste viene esaminata entro pochi giorni, ma potrebbe richiedere più tempo durante i periodi di maggiore attività."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwerkingstijden variëren afhankelijk van de beschikbaarheid van vrijwilligers. De meeste aanvragen worden binnen enkele dagen beoordeeld, maar het kan langer duren tijdens drukke periodes."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ระยะเวลาดำเนินการแตกต่างกันไปขึ้นอยู่กับความพร้อมของอาสาสมัคร การส่งข้อมูลส่วนใหญ่จะได้รับการตรวจสอบภายในไม่กี่วัน แต่อาจใช้เวลานานขึ้นในช่วงที่มีงานยุ่ง"
          }
        }
      }
    },
