    "BitLocal does not process, custody, or guarantee tip transactions. We only open your selected wallet or link and help copy/share the Lightning address." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal verarbeitet oder verwahrt Trinkgeld-Transaktionen nicht und gibt dafür keine Garantie. Wir öffnen nur deine ausgewählte Wallet oder den Link und helfen beim Kopieren oder Teilen der Lightning-Adresse."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal no procesa, custodia ni garantiza transacciones de propinas. Solo abrimos la billetera o el enlace que elijas y te ayudamos a copiar o compartir la dirección Lightning."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal no procesa, custodia ni garantiza transacciones de propinas. Solo abrimos la billetera o el enlace que elijas y te ayudamos a copiar o compartir la dirección Lightning."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal ne traite pas les pourboires, n’en assure pas la garde et ne les garantit pas. Nous ouvrons simplement le portefeuille ou le lien choisi et aidons à copier ou partager l’adresse Lightning."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal ne traite pas les pourboires, n’en assure pas la garde et ne les garantit pas. Nous ouvrons simplement le portefeuille ou le lien choisi et aidons à copier ou partager l’adresse Lightning."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal non elabora, custodisce né garantisce le transazioni di mancia. Apriamo solo il wallet o il link selezionato e ti aiutiamo a copiare o condividere l’indirizzo Lightning."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal verwerkt geen fooitransacties, bewaart ze niet en geeft er geen garantie op. We openen alleen je gekozen wallet of link en helpen je het Lightning-adres te kopiëren of te delen."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal ไม่ได้ประมวลผล ดูแลรักษา หรือรับประกันธุรกรรมทิป เราเพียงเปิดกระเป๋าเงินหรือลิงก์ที่คุณเลือก และช่วยคัดลอกหรือแชร์ที่อยู่ Lightning เท่านั้น"
          }
        }
      }
    },
    "BitLocal needs permission to send you notifications. You can turn this on in Settings." : {
