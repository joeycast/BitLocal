    "add_business_info_volunteers_description" : {
      "comment" : "Description explaining volunteer processing",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn Sie ein Unternehmen einreichen, prüfen freiwillige Community-Mitglieder bei BTC Map es und fügen es der Karte hinzu. Dies ist ein kostenloser Service, der von der Bitcoin-Community betrieben wird."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When you submit a business, volunteer community members at BTC Map review and add it to the map. This is a free service maintained by the Bitcoin community."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando envías un negocio, miembros voluntarios de la comunidad de BTC Map lo revisan y lo añaden al mapa. Este es un servicio gratuito mantenido por la comunidad Bitcoin."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando envías un negocio, miembros voluntarios de la comunidad de BTC Map lo revisan y lo agregan al mapa. Este es un servicio gratuito mantenido por la comunidad Bitcoin."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lorsque vous soumettez un établissement, des bénévoles de la communauté BTC Map l'examinent et l'ajoutent à la carte. C'est un service gratuit maintenu par la communauté Bitcoin."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lorsque vous soumettez un commerce, des bénévoles de la communauté BTC Map l'examinent et l'ajoutent à la carte. C'est un service gratuit maintenu par la communauté Bitcoin."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando invii un'attività, i membri volontari della comunità di BTC Map la esaminano e la aggiungono alla mappa. Questo è un servizio gratuito gestito dalla comunità Bitcoin."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wanneer je een bedrijf indient, beoordelen vrijwillige communityleden bij BTC Map het en voegen het toe aan de kaart. Dit is een gratis dienst die wordt onderhouden door de Bitcoin-gemeenschap."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "เมื่อคุณส่งข้อมูลธุรกิจ อาสาสมัครในชุมชน BTC Map จะตรวจสอบและเพิ่มลงในแผนที่ นี่เป็นบริการฟรีที่ดูแลโดยชุมชน Bitcoin"
          }
        }
      }
    },
