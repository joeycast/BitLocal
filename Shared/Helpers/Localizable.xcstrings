      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieses Unternehmen wurde auf BTC Map geboostet. Das bedeutet, dass jemand aus der Community dafür bezahlt hat, damit es mehr Menschen entdecken."
