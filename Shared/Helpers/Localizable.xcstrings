    "support_bitlocal_footer" : {
      "comment" : "Support BitLocal section footer",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal wird von einem unabhängigen Entwickler erstellt und gepflegt. Alle Funktionen sind kostenlos. Trinkgelder sind völlig freiwillig und schalten keine zusätzlichen Funktionen frei. Mit einem Tippen auf die Schaltfläche öffnet sich unsere Trinkgeld-Seite im Browser (außerhalb des App-Store-Zahlungssystems)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal is built and maintained by a solo, independent developer. All features are free. Tips are purely optional and never unlock extra functionality. Tapping the button opens our tip page in your browser (outside the App Store payment system)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal está desarrollado y mantenido por un desarrollador independiente. Todas las funciones son gratuitas. Las propinas son completamente opcionales y no desbloquean funciones adicionales. Al tocar el botón, se abre nuestra página de propinas en el navegador (fuera del sistema de pagos del App Store)."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal está desarrollado y mantenido por un desarrollador independiente. Todas las funciones son gratuitas. Las propinas son completamente opcionales y no desbloquean funciones adicionales. Al tocar el botón, se abrirá nuestra página de propinas en el navegador (fuera del sistema de pagos del App Store)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal est conçu et maintenu par un développeur indépendant. Toutes les fonctionnalités sont gratuites. Les pourboires sont totalement facultatifs et ne débloquent aucune fonctionnalité supplémentaire. En appuyant sur le bouton, vous ouvrez notre page de pourboires dans votre navigateur (en dehors du système de paiement de l’App Store)."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal est conçu et maintenu par un développeur indépendant. Toutes les fonctionnalités sont gratuites. Les pourboires sont entièrement facultatifs et ne débloquent aucune fonctionnalité supplémentaire. En appuyant sur le bouton, vous ouvrirez notre page de pourboires dans votre navigateur (à l’extérieur du système de paiement de l’App Store)."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal è sviluppato e mantenuto da un singolo sviluppatore indipendente. Tutte le funzionalità sono gratuite. Le mance sono completamente facoltative e non sbloccano funzionalità aggiuntive. Toccando il pulsante si apre la nostra pagina delle mance nel browser (fuori dal sistema di pagamento dell’App Store)."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal is gebouwd en onderhouden door een onafhankelijke ontwikkelaar. Alle functies zijn gratis. Fooien zijn volledig optioneel en ontgrendelen geen extra functionaliteit. Door op de knop te tikken, wordt onze tippagina in je browser geopend (buiten het App Store-betalingssysteem)."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal สร้างและดูแลโดยนักพัฒนาอิสระเพียงคนเดียว ฟีเจอร์ทั้งหมดใช้งานได้ฟรี ทิปเป็นเรื่องตามสมัครใจและไม่ได้ปลดล็อกฟีเจอร์เพิ่มเติม การแตะปุ่มจะเปิดหน้าทิปของเราในเบราว์เซอร์ (นอกระบบการชำระเงินของ App Store)"
          }
        }
      }
    },
