    "contribute_footer" : {
      "comment" : "Footer text under contribute section",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Derzeit können Unternehmen nicht direkt in der App hinzugefügt werden. Diese Funktion wird für eine zukünftige Version in Betracht gezogen. Bis dahin sende uns bitte eine E-Mail über „Unternehmen vorschlagen“ oben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "At this time, adding businesses is not supported in-app but is being considered as a feature for a future release. Until then, email us by tapping “Suggest a Business” above."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Por ahora, no se pueden agregar negocios desde la app, pero se está considerando para una versión futura. Mientras tanto, envíanos un correo tocando \"Sugerir un negocio\" arriba."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Actualmente, no es posible agregar negocios desde la aplicación, pero se está considerando como una función futura. Mientras tanto, puedes enviarnos un correo tocando \"Sugerir un negocio\" arriba."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pour le moment, il n’est pas possible d’ajouter des établissements dans l’application, mais cette fonctionnalité est envisagée pour une future version. En attendant, contactez-nous par email en appuyant sur « Suggérer un établissement » ci-dessus."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pour le moment, il n’est pas possible d’ajouter des commerces dans l’application, mais cette fonctionnalité est envisagée pour une version future. D’ici là, envoyez-nous un courriel en appuyant sur « Suggérer un commerce » ci-dessus."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al momento non è possibile aggiungere attività nell’app, ma la funzionalità è prevista per una versione futura. Nel frattempo, inviaci un’email toccando “Suggerisci un’attività” qui sopra."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Het toevoegen van bedrijven is momenteel niet mogelijk in de app, maar wordt overwogen voor een toekomstige versie. Tot die tijd kun je ons een e-mail sturen via \"Bedrijf voorstellen\" hierboven."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ขณะนี้ยังไม่สามารถเพิ่มธุรกิจในแอปได้ แต่กำลังพิจารณาเพิ่มในอนาคต ในระหว่างนี้สามารถส่งอีเมลถึงเราได้โดยแตะที่ “เสนอธุรกิจ” ด้านบน"
          }
        }
      }
    },
