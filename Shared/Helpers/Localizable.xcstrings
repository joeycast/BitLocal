    "add_business_info_data_source_description" : {
      "comment" : "Description explaining BitLocal uses BTC Map data",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal zeigt Bitcoin-akzeptierende Unternehmen von BTC Map an, einer von der Community gepflegten offenen Datenbank von Händlern weltweit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal displays Bitcoin-accepting businesses from BTC Map, a community-maintained open database of merchants worldwide."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal muestra negocios que aceptan Bitcoin de BTC Map, una base de datos abierta de comerciantes mantenida por la comunidad en todo el mundo."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal muestra negocios que aceptan Bitcoin de BTC Map, una base de datos abierta de comerciantes mantenida por la comunidad en todo el mundo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal affiche les commerces acceptant le Bitcoin depuis BTC Map, une base de données ouverte de commerçants maintenue par la communauté dans le monde entier."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal affiche les commerces acceptant le Bitcoin depuis BTC Map, une base de données ouverte de commerçants maintenue par la communauté dans le monde entier."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BitLocal mostra le attività che accettano Bitcoin da BTC Map, un database aperto di commercianti mantenuto dalla comunità in tutto il mondo."
