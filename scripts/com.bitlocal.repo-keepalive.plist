<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.bitlocal.repo-keepalive</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/zsh</string>
		<string>/ABSOLUTE/PATH/TO/bitlocal/scripts/repo_keepalive.sh</string>
		<string>/ABSOLUTE/PATH/TO/bitlocal</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>StartInterval</key>
	<integer>2592000</integer>
	<key>StandardErrorPath</key>
	<string>/tmp/com.bitlocal.repo-keepalive.err</string>
	<key>StandardOutPath</key>
	<string>/tmp/com.bitlocal.repo-keepalive.out</string>
	<key>WorkingDirectory</key>
	<string>/ABSOLUTE/PATH/TO/bitlocal</string>
</dict>
</plist>
